{%- comment -%} Shipping-policy detail box on the product detail page {%- endcomment -%}
<style>
  .pf-ship {
    margin: 1.6rem 0 0; position: relative; overflow: hidden;
    background: linear-gradient(160deg, #1e7a41 0%, #14532b 100%);
    border: 1px solid #2c7a48; border-radius: 18px; padding: 2.4rem 2.4rem 2.6rem;
    color: #eefaf0; box-shadow: 0 14px 34px rgba(20, 80, 40, .2);
  }
  .pf-ship__eyebrow {
    position: relative; display: inline-flex; align-items: center; gap: .6rem;
    font-size: 1.2rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase;
    color: #f2c14e; margin: 0 0 1.8rem;
  }
  .pf-ship__grid { position: relative; display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr)); gap: 1.4rem; }
  .pf-ship__card {
    background: rgba(255, 255, 255, .08); border: none;
    border-radius: 14px; padding: 1.6rem 1.6rem 1.4rem;
  }
  .pf-ship__h { display: flex; align-items: center; gap: 0.7rem; margin: 0 0 1.2rem; font-size: 1.55rem; font-weight: 800; color: #ffffff; }
  .pf-ship__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .pf-ship__row {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 0.55rem 0;
  }
  .pf-ship__label { font-size: 1.35rem; color: #dcefe1; line-height: 1.4; }
  .pf-ship__val {
    flex: none; max-width: 55%; text-align: center; font-size: 1.3rem; font-weight: 800; color: #14532b; background: #f2c14e;
    padding: .35rem .9rem; border-radius: 999px; line-height: 1.25;
  }
  .pf-ship__val.free { background: #d8efdd; color: #14672f; }
  .pf-ship__row.hot { background: rgba(242, 193, 78, .16); border-radius: 10px; padding: .8rem 1rem; margin: .4rem -.4rem 0; }
  .pf-ship__row.hot .pf-ship__label { color: #fff; font-weight: 700; }
  @media (max-width: 749px) { .pf-ship__grid { grid-template-columns: 1fr; } }
</style>

<div class="pf-ship">
  <p class="pf-ship__eyebrow">🌿 Chính sách vận chuyển &amp; ưu đãi</p>

  <div class="pf-ship__grid">
    <div class="pf-ship__card">
      <h3 class="pf-ship__h">🚚 Phí vận chuyển tiết kiệm</h3>
      <ul class="pf-ship__list">
        <li class="pf-ship__row"><span class="pf-ship__label">Đơn từ 0 – 10kg</span><span class="pf-ship__val">19€</span></li>
        <li class="pf-ship__row"><span class="pf-ship__label">Đơn từ 10 – 20kg</span><span class="pf-ship__val">13€</span></li>
        <li class="pf-ship__row"><span class="pf-ship__label">Đơn trên 20kg</span><span class="pf-ship__val free">Miễn phí</span></li>
      </ul>
    </div>

    <div class="pf-ship__card">
      <h3 class="pf-ship__h">🎁 Ưu đãi theo giá trị đơn</h3>
      <ul class="pf-ship__list">
        <li class="pf-ship__row"><span class="pf-ship__label">Đơn từ 150€</span><span class="pf-ship__val free">Freeship</span></li>
        <li class="pf-ship__row"><span class="pf-ship__label">Đơn từ 250€</span><span class="pf-ship__val free">Freeship +3%</span></li>
        <li class="pf-ship__row hot"><span class="pf-ship__label">Đơn từ 350€</span><span class="pf-ship__val">Giá sỉ</span></li>
      </ul>
    </div>
  </div>
</div>
