{%- comment -%}
  Floating round "Tiếp tục mua sắm" button pinned to the bottom-left corner,
  with a label pill beside it (contact-button style). Bottom-left to avoid the
  store's existing bottom-right chat/scroll widgets. Links to all products.
{%- endcomment -%}
<style>
  .pf-sideshop {
    position: fixed;
    right: 2rem;
    bottom: 2.6rem;
    z-index: 16;
    display: inline-flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }
  .pf-sideshop__btn {
    position: relative;
    flex: none;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 2.8rem;
    color: #fff;
    background: linear-gradient(180deg, #e8452f, #d62828);
    box-shadow: 0 8px 20px rgba(180, 30, 20, .35);
    transition: transform .18s ease, filter .18s ease;
  }
  .pf-sideshop__btn::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(214, 40, 40, .5);
    animation: pf-shop-pulse 2s infinite;
  }
  @keyframes pf-shop-pulse {
    0% { box-shadow: 0 0 0 0 rgba(214, 40, 40, .45); }
    70% { box-shadow: 0 0 0 14px rgba(214, 40, 40, 0); }
    100% { box-shadow: 0 0 0 0 rgba(214, 40, 40, 0); }
  }
  .pf-sideshop__label {
    background: #fff;
    color: #d62828;
    font-weight: 800;
    font-size: 1.5rem;
    padding: 1rem 1.6rem;
    border-radius: 999px;
    box-shadow: 0 6px 16px rgba(0, 0, 0, .14);
    white-space: nowrap;
  }
  .pf-sideshop:hover .pf-sideshop__btn { transform: scale(1.06); filter: brightness(1.05); }
  @media (max-width: 749px) {
    .pf-sideshop { right: 1.2rem; bottom: 1.8rem; gap: .7rem; }
    .pf-sideshop__btn { width: 5rem; height: 5rem; font-size: 2.3rem; }
    .pf-sideshop__label { font-size: 1.25rem; padding: .8rem 1.2rem; }
  }
</style>

<a class="pf-sideshop" href="{{ routes.all_products_collection_url }}" aria-label="Tiếp tục mua sắm">
  <span class="pf-sideshop__btn" aria-hidden="true">🛍️</span>
  <span class="pf-sideshop__label">Tiếp tục mua sắm</span>
</a>
