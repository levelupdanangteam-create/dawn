{%- comment -%}
  Add-to-cart + View buttons for the custom product-card sections
  (Flash Sale, Giá Tốt Mỗi Ngày, Ăn Vặt). Uses the shared .pf-card-actions
  styles in pf-brand.css and the AJAX handler in pf-cart-ajax.js.
  Params: product (required), section_id (required)
{%- endcomment -%}
<div class="pf-card-actions">
  {%- if product.available -%}
    {%- assign pf_add_id = 'pf-add-' | append: section_id | append: '-' | append: product.id -%}
    {%- form 'product', product, id: pf_add_id, class: 'pf-card-actions__form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button type="submit" class="pf-btn-cart">Thêm vào giỏ</button>
    {%- endform -%}
  {%- else -%}
    <button type="button" class="pf-btn-cart" disabled>Hết hàng</button>
  {%- endif -%}
  <a href="{{ product.url }}" class="pf-btn-view">Xem ngay</a>
</div>
