{%- comment -%}
  Order-summary box on the cart page with a "copy order details" button.
  Lets customers copy their order as text to paste into Messenger/Zalo/email.
{%- endcomment -%}
{%- unless cart == empty -%}
<style>
  .pf-ordercopy { margin: 0; background: transparent; }
  .pf-ordercopy__head { display: flex; align-items: center; gap: .8rem; padding: 1.2rem 1.6rem; background: linear-gradient(90deg, #1e8541, #14672f); color: #fff; border-radius: 12px; }
  .pf-ordercopy__head h3 { margin: 0; font-size: 1.6rem; font-weight: 800; color: #fff; }
  .pf-ordercopy__body { padding: 1.4rem .2rem 0; }
  .pf-ordercopy__list { list-style: none; margin: 0 0 1.2rem; padding: 0; display: flex; flex-direction: column; gap: .7rem; }
  .pf-ordercopy__item { display: flex; justify-content: space-between; gap: 1rem; font-size: 1.4rem; color: #2a2622; padding-bottom: .7rem; border-bottom: 1px solid #f0e8db; }
  .pf-ordercopy__item:last-child { border-bottom: none; padding-bottom: 0; }
  .pf-ordercopy__name { line-height: 1.4; }
  .pf-ordercopy__name b { color: #1e63c8; }
  .pf-ordercopy__price { flex: none; font-weight: 800; color: #1e63c8; white-space: nowrap; }
  .pf-ordercopy__total { display: flex; justify-content: space-between; align-items: center; font-size: 1.55rem; font-weight: 800; color: #2a2622; padding-top: 1rem; border-top: 2px solid #ece3d4; }
  .pf-ordercopy__total span:last-child { color: #d62828; }
  .pf-ordercopy__btn {
    margin-top: 1.4rem; width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: .6rem;
    background: linear-gradient(90deg, #1e8541, #14672f); color: #fff; border: none; cursor: pointer;
    font-size: 1.5rem; font-weight: 800; padding: 1.2rem 1.6rem; border-radius: 12px; transition: filter .15s ease;
  }
  .pf-ordercopy__btn:hover { filter: brightness(1.08); }
  .pf-ordercopy__btn.copied { background: #1e63c8; }
  .pf-ordercopy__ship { margin: 1rem 0 0; font-size: 1.3rem; color: #7a6a4a; background: #fbf3e2; border: 1px solid #f0e2c4; border-radius: 10px; padding: .8rem 1.1rem; line-height: 1.45; }
  .pf-ordercopy__ship b { color: #b8894b; }
  .pf-ordercopy__wa {
    margin-top: .9rem; width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: .7rem;
    background: #25d366; color: #fff; text-decoration: none;
    font-size: 1.5rem; font-weight: 800; padding: 1.2rem 1.6rem; border-radius: 12px; transition: filter .15s ease;
  }
  .pf-ordercopy__wa:hover { filter: brightness(1.06); }
  .pf-ordercopy__hint { margin: .9rem 0 0; font-size: 1.25rem; color: #7a7266; text-align: center; line-height: 1.5; }
  .pf-ordercopy__hint b { color: #14672f; }
  .pf-ordercopy__continue {
    margin-top: 1.4rem; width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: .6rem;
    color: #d62828; font-weight: 800; font-size: 1.5rem; text-decoration: none;
    background: #fff; border: 2px solid #d62828; border-radius: 999px; padding: 1.1rem 1.6rem;
    box-shadow: 0 4px 12px rgba(214,40,40,.12); transition: background .18s ease, color .18s ease, box-shadow .18s ease;
  }
  .pf-ordercopy__continue:hover { background: #d62828; color: #fff; box-shadow: 0 8px 18px rgba(214,40,40,.28); }
  .pf-ordercopy__src { position: absolute; left: -9999px; top: 0; opacity: 0; }
</style>

{%- capture pf_order_text -%}
🛒 ĐƠN HÀNG – PHOMIFOOD.EU
------------------------------
{% for item in cart.items -%}
{{ forloop.index }}. {{ item.product.title }}{% unless item.variant.title contains 'Default' %} ({{ item.variant.title }}){% endunless %} | SL: {{ item.quantity }} | {{ item.final_line_price | money }}
{% endfor -%}
------------------------------
TỔNG TẠM TÍNH: {{ cart.total_price | money }}
(Chưa gồm phí vận chuyển)
{%- endcapture -%}

<div class="pf-ordercopy" id="pf-ordercopy" data-currency="{{ cart.currency.iso_code }}" data-locale="{{ request.locale.iso_code | default: 'vi' }}">
  <div class="pf-ordercopy__head">
    <span aria-hidden="true">📋</span>
    <h3>Thông tin đơn hàng của bạn</h3>
  </div>
  <div class="pf-ordercopy__body">
    <ul class="pf-ordercopy__list" id="pf-oc-list">
      {%- for item in cart.items -%}
        <li class="pf-ordercopy__item">
          <span class="pf-ordercopy__name">
            {{ item.product.title }}{% unless item.variant.title contains 'Default' %} <b>({{ item.variant.title }})</b>{% endunless %}
            × {{ item.quantity }}
          </span>
          <span class="pf-ordercopy__price">{{ item.final_line_price | money }}</span>
        </li>
      {%- endfor -%}
    </ul>
    <div class="pf-ordercopy__total">
      <span>Tổng tạm tính</span>
      <span id="pf-oc-total">{{ cart.total_price | money }}</span>
    </div>
    <p class="pf-ordercopy__ship">🚚 Giá trên <b>chưa bao gồm phí vận chuyển</b> (tính khi xác nhận đơn).</p>

    <textarea class="pf-ordercopy__src" id="pf-order-src" readonly aria-hidden="true">{{ pf_order_text }}</textarea>
    <button type="button" class="pf-ordercopy__btn" id="pf-order-copy-btn" data-label="📋 Copy thông tin đơn hàng">
      📋 Copy thông tin đơn hàng
    </button>
    <a class="pf-ordercopy__wa" id="pf-order-wa" href="https://wa.me/84938227250?text={{ pf_order_text | url_encode }}" target="_blank" rel="noopener">
      <svg viewBox="0 0 32 32" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M16.003 3.2c-7.06 0-12.8 5.74-12.8 12.8 0 2.257.59 4.46 1.712 6.4L3.2 28.8l6.56-1.712a12.74 12.74 0 0 0 6.243 1.6h.005c7.06 0 12.8-5.74 12.8-12.8s-5.74-12.8-12.8-12.8zm0 23.36h-.004a10.55 10.55 0 0 1-5.375-1.472l-.386-.229-3.893 1.016 1.04-3.79-.251-.4a10.53 10.53 0 0 1-1.613-5.615c0-5.83 4.744-10.573 10.577-10.573 2.826 0 5.48 1.1 7.478 3.1a10.5 10.5 0 0 1 3.096 7.48c0 5.83-4.744 10.573-10.576 10.573zm5.8-7.92c-.318-.16-1.88-.928-2.172-1.034-.291-.106-.503-.16-.715.16-.212.318-.82 1.033-1.006 1.245-.185.212-.371.239-.689.08-.318-.16-1.343-.495-2.558-1.578-.945-.843-1.583-1.884-1.769-2.202-.185-.318-.02-.49.14-.649.143-.142.318-.371.477-.557.16-.185.212-.318.318-.53.106-.212.053-.398-.027-.557-.08-.16-.715-1.724-.98-2.36-.258-.62-.52-.536-.715-.546l-.61-.011c-.212 0-.557.08-.848.398-.291.318-1.113 1.087-1.113 2.651s1.14 3.075 1.298 3.287c.16.212 2.242 3.423 5.431 4.8.759.328 1.351.524 1.813.67.762.242 1.455.208 2.003.126.611-.091 1.88-.769 2.145-1.511.265-.742.265-1.378.185-1.511-.079-.133-.291-.212-.61-.371z"/></svg>
      Gửi đơn qua WhatsApp
    </a>
    <p class="pf-ordercopy__hint">Hoặc <b>copy đơn</b> rồi gửi vào <b>Fanpage / Messenger của PHOMIFOOD</b> để được tư vấn kỹ hơn.</p>

    <a class="pf-ordercopy__continue" href="{{ routes.all_products_collection_url }}">🛍️ Tiếp tục mua sắm</a>
  </div>
</div>

<script>
  (function () {
    if (window.pfOrderCopyBound) return;
    window.pfOrderCopyBound = true;

    var box = document.getElementById('pf-ordercopy');
    var root = (window.Shopify && Shopify.routes ? Shopify.routes.root : '/');

    function money(cents, cur, loc) {
      try { return new Intl.NumberFormat(loc, { style: 'currency', currency: cur }).format((cents || 0) / 100); }
      catch (e) { return ((cents || 0) / 100).toFixed(2); }
    }
    function esc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : s; return d.innerHTML; }

    // Rebuild the order summary + copy text from the live cart so it stays in
    // sync when quantities change or items are removed on the cart page.
    function rebuild() {
      var b = document.getElementById('pf-ordercopy');
      if (!b) return;
      var cur = b.getAttribute('data-currency') || 'EUR';
      var loc = b.getAttribute('data-locale') || 'vi';
      fetch(root + 'cart.js', { headers: { Accept: 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          var list = document.getElementById('pf-oc-list');
          var totalEl = document.getElementById('pf-oc-total');
          var src = document.getElementById('pf-order-src');
          var rows = '', text = '🛒 ĐƠN HÀNG – PHOMIFOOD.EU\n------------------------------\n';
          (cart.items || []).forEach(function (it, i) {
            var vt = (it.variant_title && it.variant_title.indexOf('Default') === -1) ? it.variant_title : '';
            var line = money(it.final_line_price, cur, loc);
            rows += '<li class="pf-ordercopy__item"><span class="pf-ordercopy__name">' + esc(it.product_title) +
              (vt ? ' <b>(' + esc(vt) + ')</b>' : '') + ' × ' + it.quantity +
              '</span><span class="pf-ordercopy__price">' + line + '</span></li>';
            text += (i + 1) + '. ' + it.product_title + (vt ? ' (' + vt + ')' : '') +
              ' | SL: ' + it.quantity + ' | ' + line + '\n';
          });
          text += '------------------------------\nTỔNG TẠM TÍNH: ' + money(cart.total_price, cur, loc) + '\n(Chưa gồm phí vận chuyển)';
          if (list) list.innerHTML = rows;
          if (totalEl) totalEl.textContent = money(cart.total_price, cur, loc);
          if (src) src.value = text;
          var wa = document.getElementById('pf-order-wa');
          if (wa) wa.href = 'https://wa.me/84938227250?text=' + encodeURIComponent(text);
        })
        .catch(function () {});
    }
    window.pfOrderCopyRebuild = rebuild;

    // Re-sync whenever the header cart bubble changes (Dawn re-renders it on
    // every quantity/remove change on the cart page).
    var bubble = document.getElementById('cart-icon-bubble');
    if (bubble && 'MutationObserver' in window) {
      var t;
      new MutationObserver(function () {
        clearTimeout(t);
        t = setTimeout(rebuild, 250);
      }).observe(bubble, { childList: true, subtree: true });
    }
    document.addEventListener('pf:cart:added', rebuild);

    document.addEventListener('click', function (e) {
      var btn = e.target.closest ? e.target.closest('#pf-order-copy-btn') : null;
      if (!btn) return;
      var src = document.getElementById('pf-order-src');
      if (!src) return;
      var text = src.value;
      function done() {
        btn.classList.add('copied');
        btn.textContent = '✅ Đã copy!';
        setTimeout(function () {
          btn.classList.remove('copied');
          btn.textContent = btn.getAttribute('data-label');
        }, 1800);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function () {
          src.select(); document.execCommand('copy'); done();
        });
      } else {
        src.select(); document.execCommand('copy'); done();
      }
    });
  })();
</script>
{%- endunless -%}
