{%- comment -%}
  "Thường được mua kèm" block for the product page. Shows products from the
  best-sellers collection (ban-chay-nhat), excluding the current product.
  Uses custom cards with product.featured_image (some products lack
  featured_media, which makes card-product render without an image).
  Optional params: bt_handle (collection handle), bt_limit (max products).
{%- endcomment -%}
{%- assign bt_handle = bt_handle | default: 'ban-chay-nhat' -%}
{%- assign bt_limit = bt_limit | default: 4 -%}
{%- assign bt_coll = collections[bt_handle] -%}
{%- if bt_coll != empty and bt_coll.products_count > 0 -%}
  {%- assign bt_shown = 0 -%}
  <style>
    .pf-bt {
      max-width: var(--page-width, 120rem); margin: clamp(3rem, 6vw, 6rem) auto 0;
      background: #fff; border: 1px solid #ece3d4; border-radius: 22px;
      padding: clamp(2.4rem, 3.5vw, 4rem) clamp(1.6rem, 3vw, 3.2rem); box-shadow: 0 12px 32px rgba(120,100,70,.08);
    }
    .pf-bt__head { text-align: center; margin-bottom: 2.8rem; }
    .pf-bt__title {
      display: inline-flex; align-items: center; gap: .8rem; position: relative; margin: 0;
      font-family: var(--font-heading-family, sans-serif); font-weight: 800; font-size: clamp(2rem, 3vw, 2.8rem); line-height: 1.15;
      color: #d62828; background: linear-gradient(90deg, #d62828 0%, #e8452f 55%, #f2792a 100%);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }
    .pf-bt__head::after { content: ""; display: block; width: 6rem; height: 4px; border-radius: 4px; margin: 1.1rem auto 0; background: linear-gradient(90deg, #d62828, #f2792a); }
    .pf-bt__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(1.4rem, 2vw, 2.2rem); }
    .pf-bt__card { display: flex; flex-direction: column; }
    .pf-bt__media {
      display: grid; place-items: center; aspect-ratio: 4 / 3; max-height: 22rem; overflow: hidden;
      background: #fff; border: 1px solid #f0e8db; border-radius: 14px; position: relative;
    }
    .pf-bt__media img { width: 100%; height: 100%; object-fit: contain; padding: 8px; transition: transform .3s ease; }
    .pf-bt__card:hover .pf-bt__media img { transform: scale(1.05); }
    .pf-bt__sale { position: absolute; top: .8rem; left: .8rem; background: #d62828; color: #fff; font-weight: 800; font-size: 1.2rem; padding: .3rem .7rem; border-radius: 6px; }
    .pf-bt__nm {
      margin: 1.2rem 0 .5rem; font-size: 1.55rem; font-weight: 700; line-height: 1.35; min-height: 2.7em;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .pf-bt__nm a { color: #2a2622; text-decoration: none; }
    .pf-bt__nm a:hover { color: #1e63c8; }
    .pf-bt__price { margin-bottom: 1rem; }
    .pf-bt__price .now { color: #1e63c8; font-weight: 800; font-size: 1.7rem; }
    .pf-bt__price .was { color: #9a9184; text-decoration: line-through; font-size: 1.35rem; margin-left: .6rem; }
    @media (max-width: 989px) { .pf-bt__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 499px) { .pf-bt__grid { grid-template-columns: 1fr; } }
  </style>

  <div class="pf-bt color-scheme-1">
    <div class="pf-bt__head">
      <h2 class="pf-bt__title"><span aria-hidden="true">🛒</span> Thường được mua kèm</h2>
    </div>
    <div class="pf-bt__grid">
      {%- for p in bt_coll.products -%}
        {%- if p.id != product.id and bt_shown < bt_limit -%}
          <div class="pf-bt__card">
            <a class="pf-bt__media" href="{{ p.url }}">
              {%- if p.compare_at_price > p.price -%}
                <span class="pf-bt__sale">-{{ p.compare_at_price | minus: p.price | times: 100.0 | divided_by: p.compare_at_price | round }}%</span>
              {%- endif -%}
              {%- if p.featured_image -%}
                <img src="{{ p.featured_image | image_url: width: 500 }}" alt="{{ p.title | escape }}" loading="lazy" width="500" height="500">
              {%- else -%}
                {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <h3 class="pf-bt__nm"><a href="{{ p.url }}">{{ p.title }}</a></h3>
            <div class="pf-bt__price">
              <span class="now">{{ p.price | money }}</span>
              {%- if p.compare_at_price > p.price -%}<span class="was">{{ p.compare_at_price | money }}</span>{%- endif -%}
            </div>
            {% render 'pf-card-buttons', product: p, section_id: 'bought-together' %}
          </div>
          {%- assign bt_shown = bt_shown | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}
