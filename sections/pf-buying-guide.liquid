<style>
  #pf-guide-{{ section.id }} {
    background: #1e63c8; color: #ffffff;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #pf-guide-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: 2rem; }
  #pf-guide-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; color: #ffffff;
    font-size: 2.2rem; margin: 0 0 3rem; text-align: center;
  }
  #pf-guide-{{ section.id }} .pf-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  #pf-guide-{{ section.id }} .pf-step { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.2rem; }
  #pf-guide-{{ section.id }} .pf-num {
    width: 5.6rem; height: 5.6rem; border-radius: 50%; background: #1e63c8; color: #fff;
    display: grid; place-items: center; font-size: 2.4rem; font-weight: 800;
  }
  #pf-guide-{{ section.id }} .pf-step-title { margin: 0; font-size: 1.6rem; font-weight: 700; color: #fff; }
  #pf-guide-{{ section.id }} .pf-step-desc { margin: 0; font-size: 1.35rem; line-height: 1.5; color: rgba(255,255,255,.85); max-width: 26ch; }
  @media (max-width: 749px) { #pf-guide-{{ section.id }} .pf-steps { grid-template-columns: repeat(2, 1fr); gap: 2.8rem; } }
  @media (max-width: 459px) { #pf-guide-{{ section.id }} .pf-steps { grid-template-columns: 1fr; } }
</style>

<div id="pf-guide-{{ section.id }}">
  <div class="pf-wrap">
    <h2 class="pf-title">{{ section.settings.heading }}</h2>
    <div class="pf-steps">
      {%- for block in section.blocks -%}
        <div class="pf-step" {{ block.shopify_attributes }}>
          <span class="pf-num">{{ forloop.index }}</span>
          <h3 class="pf-step-title">{{ block.settings.title }}</h3>
          <p class="pf-step-desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hướng Dẫn Mua Hàng",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Mua Hàng Dễ Dàng" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 56 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Bước",
      "settings": [
        { "type": "text", "id": "title", "label": "Tiêu đề bước", "default": "Chọn sản phẩm" },
        { "type": "textarea", "id": "description", "label": "Mô tả", "default": "Vào phomifood.eu, chọn món bạn thích" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hướng Dẫn Mua Hàng",
      "blocks": [
        { "type": "step", "settings": { "title": "Chọn sản phẩm", "description": "Vào phomifood.eu, chọn món bạn thích" } },
        { "type": "step", "settings": { "title": "Thêm vào giỏ", "description": "Chọn số lượng, bấm Thêm vào giỏ" } },
        { "type": "step", "settings": { "title": "Đặt hàng", "description": "Điền địa chỉ, chọn thanh toán COD hoặc chuyển khoản" } },
        { "type": "step", "settings": { "title": "Nhận hàng", "description": "Giao toàn châu Âu, Séc có thể nhận trong ngày" } }
      ]
    }
  ]
}
{% endschema %}
