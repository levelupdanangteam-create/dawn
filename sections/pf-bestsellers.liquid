<style>
  #pf-bs-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #pf-bs-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  #pf-bs-{{ section.id }} .pf-bs { --cols: {{ section.settings.columns_desktop }}; }
  #pf-bs-{{ section.id }} .pf-bs__head { text-align: center; margin-bottom: 2.8rem; }
  #pf-bs-{{ section.id }} .pf-bs__eyebrow { display: inline-block; font-size: 1.2rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: #1e63c8; margin-bottom: 0.8rem; }
  #pf-bs-{{ section.id }} .pf-bs__title { font-family: var(--font-heading-family, sans-serif); font-weight: 800; font-size: clamp(2.2rem, 3.4vw, 3.2rem); color: #2a2622; margin: 0; line-height: 1.15; }
  #pf-bs-{{ section.id }} .pf-bs__title::after { content: ""; display: block; width: 6rem; height: 4px; border-radius: 4px; margin: 1.2rem auto 0; background: linear-gradient(90deg, #1e63c8, #6aa0ef); }
  #pf-bs-{{ section.id }} .pf-bs__sub { margin: 1rem auto 0; max-width: 52ch; color: #6b6357; font-size: 1.45rem; }

  #pf-bs-{{ section.id }} .pf-bs__grid { display: grid; grid-template-columns: repeat(var(--cols), 1fr); gap: 1.8rem; }
  #pf-bs-{{ section.id }} .pf-bs__card {
    position: relative; background: #fff; border: 1px solid #ece4d8; border-radius: 16px; overflow: hidden;
    display: flex; flex-direction: column; transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  #pf-bs-{{ section.id }} .pf-bs__card:hover { transform: translateY(-5px); box-shadow: 0 16px 36px rgba(30,60,120,.14); border-color: #cfe0fb; }

  #pf-bs-{{ section.id }} .pf-bs__rank {
    position: absolute; top: 0; left: 0; z-index: 3; width: 4.2rem; height: 4.2rem;
    display: grid; place-items: center; font-weight: 800; font-size: 1.5rem; color: #fff;
    background: #1e63c8; border-radius: 16px 0 16px 0; box-shadow: 0 4px 10px rgba(0,0,0,.15);
  }
  #pf-bs-{{ section.id }} .pf-bs__rank.r1 { background: linear-gradient(135deg, #f6d36b, #d99b0b); color: #4a3500; }
  #pf-bs-{{ section.id }} .pf-bs__rank.r2 { background: linear-gradient(135deg, #dfe4e9, #a9b2bc); color: #384049; }
  #pf-bs-{{ section.id }} .pf-bs__rank.r3 { background: linear-gradient(135deg, #e6bd93, #c58a5b); color: #4a2f16; }

  #pf-bs-{{ section.id }} .pf-bs__media { position: relative; aspect-ratio: 1; background: #f7f1e9; display: grid; place-items: center; overflow: hidden; }
  #pf-bs-{{ section.id }} .pf-bs__media img, #pf-bs-{{ section.id }} .pf-bs__media svg { width: 100%; height: 100%; object-fit: cover; transition: transform .3s ease; }
  #pf-bs-{{ section.id }} .pf-bs__card:hover .pf-bs__media img { transform: scale(1.06); }
  #pf-bs-{{ section.id }} .pf-bs__sale { position: absolute; top: 1rem; right: 1rem; background: #d62828; color: #fff; font-size: 1.1rem; font-weight: 800; padding: .35rem .8rem; border-radius: 7px; }

  #pf-bs-{{ section.id }} .pf-bs__info { padding: 1.3rem 1.4rem 1.6rem; display: flex; flex-direction: column; gap: .6rem; flex: 1; }
  #pf-bs-{{ section.id }} .pf-bs__tag { align-self: flex-start; background: #fdecd2; color: #c9791a; font-size: 1.05rem; font-weight: 800; padding: .3rem .8rem; border-radius: 7px; }
  #pf-bs-{{ section.id }} .pf-bs__nm { margin: 0; font-size: 1.4rem; font-weight: 600; line-height: 1.35; color: #2a2622; }
  #pf-bs-{{ section.id }} .pf-bs__nm a { color: inherit; text-decoration: none; }
  #pf-bs-{{ section.id }} .pf-bs__nm a:hover { color: #1e63c8; }
  #pf-bs-{{ section.id }} .pf-bs__price { display: flex; align-items: baseline; gap: .8rem; font-variant-numeric: tabular-nums; }
  #pf-bs-{{ section.id }} .pf-bs__price .now { font-size: 1.65rem; font-weight: 800; color: #1e63c8; }
  #pf-bs-{{ section.id }} .pf-bs__price .was { font-size: 1.2rem; color: #a79c8e; text-decoration: line-through; }

  @media (max-width: 989px) { #pf-bs-{{ section.id }} .pf-bs__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 599px) { #pf-bs-{{ section.id }} .pf-bs__grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; } }
</style>

<div id="pf-bs-{{ section.id }}" class="pf-boxed-section">
  <div class="pf-wrap">
    <div class="pf-bs">
      <div class="pf-bs__head">
        <span class="pf-bs__eyebrow">🔥 Được mua nhiều nhất</span>
        <h2 class="pf-bs__title">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}<p class="pf-bs__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>

      <div class="pf-bs__grid">
        {%- assign col = section.settings.collection -%}
        {%- if col != blank and col.products_count > 0 -%}
          {%- for product in col.products limit: section.settings.products_to_show -%}
            {%- assign rank = forloop.index -%}
            <div class="pf-bs__card">
              <div class="pf-bs__rank r{{ rank }}">{{ rank }}</div>
              <a class="pf-bs__media" href="{{ product.url }}">
                {%- if product.compare_at_price > product.price -%}
                  <span class="pf-bs__sale">-{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%</span>
                {%- endif -%}
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy" width="500" height="500">
                {%- else -%}
                  {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>
              <div class="pf-bs__info">
                <span class="pf-bs__tag">🔥 Bán chạy</span>
                <h3 class="pf-bs__nm"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                <div class="pf-bs__price">
                  <span class="now">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}<span class="was">{{ product.compare_at_price | money }}</span>{%- endif -%}
                </div>
                {% render 'pf-card-buttons', product: product, section_id: section.id %}
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..section.settings.products_to_show) -%}
            <div class="pf-bs__card">
              <div class="pf-bs__rank r{{ forloop.index }}">{{ forloop.index }}</div>
              <div class="pf-bs__media">{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              <div class="pf-bs__info">
                <span class="pf-bs__tag">🔥 Bán chạy</span>
                <h3 class="pf-bs__nm">Tên sản phẩm</h3>
                <div class="pf-bs__price"><span class="now">0&nbsp;€</span></div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bán chạy nhất",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Sản phẩm bán chạy nhất" },
    { "type": "text", "id": "subheading", "label": "Phụ đề", "default": "Những sản phẩm được khách hàng yêu thích và đặt mua nhiều nhất" },
    { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
    { "type": "range", "id": "products_to_show", "min": 3, "max": 20, "step": 1, "label": "Số sản phẩm", "default": 10 },
    { "type": "range", "id": "columns_desktop", "min": 3, "max": 6, "step": 1, "label": "Số cột (desktop)", "default": 5 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 40 }
  ],
  "presets": [{ "name": "Bán chạy nhất" }]
}
{% endschema %}
