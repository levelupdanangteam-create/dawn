{{ 'phomifood.css' | asset_url | stylesheet_tag }}

<style>
  #pf-cats-{{ section.id }} { background: var(--pf-cream); border-block: 1px solid var(--pf-line); }
  #pf-cats-{{ section.id }} .pf-wrap { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  #pf-cats-{{ section.id }} .pf-cat-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 1.2rem;
  }
  #pf-cats-{{ section.id }} .pf-cat { display: flex; flex-direction: column; align-items: center; gap: 0.9rem; text-align: center; }
  #pf-cats-{{ section.id }} .pf-cat .ring {
    width: 8.4rem; height: 8.4rem; border-radius: 50%; background: #fff;
    border: 1.5px solid var(--pf-line); display: grid; place-items: center; color: var(--pf-red);
    overflow: hidden; transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }
  #pf-cats-{{ section.id }} .pf-cat .ring img { width: 100%; height: 100%; object-fit: cover; }
  #pf-cats-{{ section.id }} .pf-cat:hover .ring { transform: translateY(-3px); box-shadow: var(--pf-shadow); border-color: var(--pf-gold); }
  #pf-cats-{{ section.id }} .pf-cat.special .ring { background: var(--pf-red); border-color: var(--pf-red); color: #fff; }
  #pf-cats-{{ section.id }} .pf-cat.special:hover .ring { background: var(--pf-red-deep); }
  #pf-cats-{{ section.id }} .pf-cat .lbl { font-size: 1.15rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #5a5047; line-height: 1.25; }
  #pf-cats-{{ section.id }} .pf-cat.special .lbl { color: var(--pf-red); }
  @media screen and (max-width: 749px) {
    #pf-cats-{{ section.id }} .pf-cat-grid { grid-template-columns: repeat(4, 1fr); row-gap: 2rem; }
  }
  @media screen and (max-width: 480px) {
    #pf-cats-{{ section.id }} .pf-cat-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<div id="pf-cats-{{ section.id }}" class="pf-section">
  <div class="pf-wrap">
    <div class="pf-cat-grid">
      {%- for block in section.blocks -%}
        <a
          class="pf-cat{% if block.settings.special %} special{% endif %}"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% else %}href="#" role="link" aria-disabled="true"{% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="ring">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.label }}
            {%- elsif block.settings.special -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M19 5 5 19"/><circle cx="7.5" cy="7.5" r="2.2"/><circle cx="16.5" cy="16.5" r="2.2"/></svg>
            {%- else -%}
              <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M6 11c.6-3 3-5 6-5s5.4 2 6 5"/><path d="M12 2v3"/></svg>
            {%- endif -%}
          </span>
          <span class="lbl">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Phomifood Danh mục",
  "tag": "section",
  "class": "pf-categories-section",
  "max_blocks": 12,
  "settings": [
    { "type": "range", "id": "columns", "min": 4, "max": 8, "step": 1, "label": "Số cột (desktop)", "default": 8 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 26 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 26 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Danh mục",
      "settings": [
        { "type": "text", "id": "label", "label": "Tên danh mục", "default": "Danh mục" },
        { "type": "url", "id": "link", "label": "Liên kết" },
        { "type": "image_picker", "id": "image", "label": "Ảnh (tuỳ chọn)", "info": "Để trống sẽ hiện biểu tượng mặc định." },
        { "type": "checkbox", "id": "special", "label": "Kiểu nổi bật (nền đỏ)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Phomifood Danh mục",
      "blocks": [
        { "type": "category", "settings": { "label": "Mì & Bún" } },
        { "type": "category", "settings": { "label": "Nước mắm" } },
        { "type": "category", "settings": { "label": "Gia vị" } },
        { "type": "category", "settings": { "label": "Đồ khô" } },
        { "type": "category", "settings": { "label": "Đồ uống" } },
        { "type": "category", "settings": { "label": "Bánh kẹo" } },
        { "type": "category", "settings": { "label": "Đồ ăn nhanh" } },
        { "type": "category", "settings": { "label": "Ưu đãi đặc biệt", "special": true } }
      ]
    }
  ]
}
{% endschema %}
