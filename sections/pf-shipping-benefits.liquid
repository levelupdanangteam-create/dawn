<style>
  #pf-ship-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #pf-ship-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  #pf-ship-{{ section.id }} .pf-head { text-align: center; margin-bottom: 3rem; }
  #pf-ship-{{ section.id }} .pf-ornament { display: flex; align-items: center; justify-content: center; gap: 1.2rem; margin-bottom: 1rem; }
  #pf-ship-{{ section.id }} .pf-ornament .line { width: clamp(3rem, 8vw, 6rem); height: 1px; background: linear-gradient(90deg, transparent, #c9a24a); }
  #pf-ship-{{ section.id }} .pf-ornament .line + .line { background: linear-gradient(90deg, #c9a24a, transparent); }
  #pf-ship-{{ section.id }} .pf-ornament .dia { width: 9px; height: 9px; background: #c9a24a; transform: rotate(45deg); }
  #pf-ship-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 700; color: #2a2622;
    font-size: clamp(2.2rem, 3.6vw, 3.2rem); margin: 0 0 .8rem; line-height: 1.15;
  }
  #pf-ship-{{ section.id }} .pf-sub { font-size: 1.5rem; color: #55606f; margin: 0; font-weight: 500; }

  #pf-ship-{{ section.id }} .pf-grid { display: grid; grid-template-columns: repeat(var(--pf-cols, 4), 1fr); gap: 1.8rem; max-width: 108rem; margin-inline: auto; }
  #pf-ship-{{ section.id }} .pf-ben {
    position: relative; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem;
    padding: 2.4rem 1.6rem; background: #fff; border: 1px solid #ece3d4; border-radius: 18px;
    box-shadow: 0 8px 22px rgba(120,100,70,.08); transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  #pf-ship-{{ section.id }} .pf-ben:hover { transform: translateY(-6px); box-shadow: 0 18px 34px rgba(30,60,120,.16); border-color: #bcd3f7; }
  #pf-ship-{{ section.id }} .pf-ben .ic {
    width: 6rem; height: 6rem; border-radius: 50%; display: grid; place-items: center; font-size: 2.8rem; line-height: 1;
    background: radial-gradient(circle at 50% 35%, #eaf1fd 0%, #dbe8fb 100%); box-shadow: 0 8px 18px rgba(30,60,120,.14);
  }
  #pf-ship-{{ section.id }} .pf-ben .t { font-size: 1.7rem; font-weight: 800; color: #1e63c8; line-height: 1.25; }
  #pf-ship-{{ section.id }} .pf-ben .d { font-size: 1.4rem; color: #555; line-height: 1.5; }

  #pf-ship-{{ section.id }} .pf-ben.is-gold { border-color: #e8cf90; background: linear-gradient(180deg, #fffaf0 0%, #fffdf9 100%); }
  #pf-ship-{{ section.id }} .pf-ben.is-gold .ic { background: radial-gradient(circle at 50% 35%, #fbeec6 0%, #f3dda0 100%); box-shadow: 0 8px 18px rgba(180,140,50,.22); }
  #pf-ship-{{ section.id }} .pf-ben.is-gold .t { color: #b8894b; }
  #pf-ship-{{ section.id }} .pf-ben .badge {
    position: absolute; top: 1.2rem; right: 1.2rem; font-size: 1rem; font-weight: 800; letter-spacing: .04em;
    text-transform: uppercase; color: #fff; background: #d62828; padding: .3rem .7rem; border-radius: 999px;
  }
  #pf-ship-{{ section.id }} .pf-ben.is-gold .badge { background: #c9a24a; }

  @media (max-width: 989px) { #pf-ship-{{ section.id }} .pf-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 479px) { #pf-ship-{{ section.id }} .pf-grid { grid-template-columns: 1fr; } }
</style>

<div id="pf-ship-{{ section.id }}">
  <div class="pf-wrap">
    <div class="pf-head">
      <div class="pf-ornament" aria-hidden="true">
        <span class="line"></span>
        <span class="dia"></span>
        <span class="line"></span>
      </div>
      {%- if section.settings.heading != blank -%}<h2 class="pf-title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<p class="pf-sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>

    <div class="pf-grid" style="--pf-cols: {{ section.blocks.size | at_most: 4 }};">
      {%- for block in section.blocks -%}
        <div class="pf-ben{% if block.settings.highlight %} is-gold{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.badge != blank -%}<span class="badge">{{ block.settings.badge }}</span>{%- endif -%}
          {%- if block.settings.icon != blank -%}<span class="ic">{{ block.settings.icon }}</span>{%- endif -%}
          {%- if block.settings.title != blank -%}<span class="t">{{ block.settings.title }}</span>{%- endif -%}
          {%- if block.settings.desc != blank -%}<span class="d">{{ block.settings.desc }}</span>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ưu đãi & Vận chuyển",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Ưu đãi dành cho mọi đơn hàng" },
    { "type": "text", "id": "subheading", "label": "Phụ đề", "default": "🌍 Ship nhanh toàn Châu Âu — phí chỉ từ 13€ (đơn 10–20kg)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 40 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Ô ưu đãi",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🚚" },
        { "type": "text", "id": "title", "label": "Tiêu đề" },
        { "type": "textarea", "id": "desc", "label": "Mô tả" },
        { "type": "text", "id": "badge", "label": "Nhãn góc (tuỳ chọn)" },
        { "type": "checkbox", "id": "highlight", "label": "Kiểu nổi bật (vàng)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ưu đãi & Vận chuyển",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "🚚", "title": "Phí ship tiết kiệm", "desc": "0–10kg: 19€  •  10–20kg: 13€" } },
        { "type": "benefit", "settings": { "icon": "🎁", "title": "Freeship từ 150€", "desc": "Miễn phí vận chuyển cho đơn từ 150€" } },
        { "type": "benefit", "settings": { "icon": "💚", "title": "Freeship + Giảm 3%", "desc": "Áp dụng cho đơn từ 250€", "badge": "Hot", "highlight": true } },
        { "type": "benefit", "settings": { "icon": "🏷️", "title": "Giá sỉ từ 350€", "desc": "Đơn từ 350€ được áp dụng giá sỉ", "badge": "VIP", "highlight": true } }
      ]
    }
  ]
}
{% endschema %}
