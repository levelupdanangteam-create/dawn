<style>
  #pf-catgrid-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #pf-catgrid-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  #pf-catgrid-{{ section.id }} .pf-cathead { text-align: center; margin-bottom: 3.4rem; }
  #pf-catgrid-{{ section.id }} .pf-ornament { display: flex; align-items: center; justify-content: center; gap: 1.2rem; margin-bottom: 1rem; }
  #pf-catgrid-{{ section.id }} .pf-ornament .line { width: clamp(3rem, 8vw, 6rem); height: 1px; background: linear-gradient(90deg, transparent, #c9a24a); }
  #pf-catgrid-{{ section.id }} .pf-ornament .line + .line { background: linear-gradient(90deg, #c9a24a, transparent); }
  #pf-catgrid-{{ section.id }} .pf-ornament .dia { width: 9px; height: 9px; background: #c9a24a; transform: rotate(45deg); }
  #pf-catgrid-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 700; color: #2a2622;
    font-size: clamp(2.4rem, 3.8vw, 3.4rem); margin: 0; line-height: 1.15;
  }

  #pf-catgrid-{{ section.id }} .pf-grid { display: grid; grid-template-columns: repeat(var(--pf-cols, 5), 1fr); gap: clamp(1.6rem, 3vw, 3rem); max-width: 96rem; margin-inline: auto; }
  #pf-catgrid-{{ section.id }} .pf-cat {
    display: flex; flex-direction: column; align-items: center; gap: 1.4rem; text-align: center;
  }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb {
    width: 100%; max-width: 15rem; aspect-ratio: 1; border-radius: 50%; overflow: hidden;
    display: grid; place-items: center; background: #f1ece3; color: #1e63c8;
    box-shadow: 0 10px 26px rgba(120,100,70,.14);
    transition: box-shadow .25s ease, transform .25s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .thumb { transform: translateY(-6px); box-shadow: 0 18px 34px rgba(120,100,70,.24); }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .thumb img { transform: scale(1.08); }

  #pf-catgrid-{{ section.id }} .pf-cat .name {
    font-size: 1.35rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
    color: #3a332c; line-height: 1.35; text-decoration: none; transition: color .18s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .name { color: #1e63c8; }

  @media (max-width: 989px) { #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 599px) {
    #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem 1.4rem; }
    #pf-catgrid-{{ section.id }} .pf-cat .name { font-size: 1.2rem; letter-spacing: .08em; }
  }
</style>

<div id="pf-catgrid-{{ section.id }}">
  <div class="pf-wrap">
    <div class="pf-cathead">
      <div class="pf-ornament" aria-hidden="true">
        <span class="line"></span>
        <span class="dia"></span>
        <span class="line"></span>
      </div>
      <h2 class="pf-title">{{ section.settings.heading }}</h2>
    </div>
    <div class="pf-grid" style="--pf-cols: {{ section.blocks.size | at_most: 6 }};">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- if block.settings.label != blank -%}
          {%- assign cat_label = block.settings.label -%}
        {%- elsif col != blank -%}
          {%- assign cat_label = col.title -%}
        {%- else -%}
          {%- assign cat_label = 'Tên danh mục' -%}
        {%- endif -%}
        {%- if col != blank -%}{%- assign cat_url = col.url -%}{%- else -%}{%- assign cat_url = '#' -%}{%- endif -%}
        <div class="pf-cat" {{ block.shopify_attributes }}>
          <a class="thumb" href="{{ cat_url }}" aria-label="{{ cat_label | escape }}">
            {%- if col != blank and col.image -%}
              <img src="{{ col.image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy" width="300" height="300">
            {%- elsif col != blank and col.products.first.featured_image -%}
              <img src="{{ col.products.first.featured_image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy" width="300" height="300">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>
          <a class="name" href="{{ cat_url }}">{{ cat_label }}<span class="arrow" aria-hidden="true">→</span></a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Danh Mục Sản Phẩm",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Danh Mục Sản Phẩm" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Ô danh mục",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
        { "type": "text", "id": "label", "label": "Tên hiển thị (nếu chưa chọn bộ sưu tập)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Danh Mục Sản Phẩm",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
