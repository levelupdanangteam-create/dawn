<style>
  #pf-catgrid-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #pf-catgrid-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  #pf-catgrid-{{ section.id }} .pf-cathead { text-align: center; margin-bottom: 3rem; }
  #pf-catgrid-{{ section.id }} .pf-eyebrow { display: inline-block; font-size: 1.2rem; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; color: #1e63c8; margin-bottom: .8rem; }
  #pf-catgrid-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; color: #2a2622;
    font-size: clamp(2.2rem, 3.4vw, 3.2rem); margin: 0; line-height: 1.15;
  }
  #pf-catgrid-{{ section.id }} .pf-title::after { content: ""; display: block; width: 6rem; height: 4px; border-radius: 4px; margin: 1.2rem auto 0; background: linear-gradient(90deg, #1e63c8, #6aa0ef); }

  #pf-catgrid-{{ section.id }} .pf-grid { display: grid; grid-template-columns: repeat(var(--pf-cols, 5), 1fr); gap: 2rem; max-width: 100rem; margin-inline: auto; }
  #pf-catgrid-{{ section.id }} .pf-cat {
    display: flex; flex-direction: column; align-items: center; gap: 1.4rem; text-align: center;
    padding: 2.2rem 1rem 1.9rem; background: #fff;
    border: 1px solid #ece3d4; border-radius: 18px;
    box-shadow: 0 8px 22px rgba(120,100,70,.09); transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 36px rgba(30,60,120,.18); border-color: #bcd3f7;
  }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb {
    width: 10.5rem; height: 10.5rem; border-radius: 50%; overflow: hidden; display: grid; place-items: center;
    background: radial-gradient(circle at 50% 35%, #eaf1fd 0%, #dbe8fb 100%); border: 4px solid #fff;
    box-shadow: 0 0 0 1px #d3e1f7, 0 10px 22px rgba(30,60,120,.14); color: #1e63c8;
    transition: box-shadow .2s ease, transform .2s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .thumb { transform: scale(1.03); box-shadow: 0 0 0 1px #9dc0f2, 0 14px 28px rgba(30,60,120,.24); }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .35s ease; }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .thumb img { transform: scale(1.08); }
  #pf-catgrid-{{ section.id }} .pf-cat .name { font-size: 1.45rem; font-weight: 700; color: #2a2622; line-height: 1.3; text-decoration: none; transition: color .18s ease; }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .name { color: #1e63c8; }
  @media (max-width: 989px) { #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(3, 1fr); gap: 1.6rem; } }
  @media (max-width: 599px) {
    #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
    #pf-catgrid-{{ section.id }} .pf-cat { padding: 1.6rem .8rem 1.4rem; }
    #pf-catgrid-{{ section.id }} .pf-cat .thumb { width: 8.5rem; height: 8.5rem; }
    #pf-catgrid-{{ section.id }} .pf-cat .name { font-size: 1.3rem; }
  }
</style>

<div id="pf-catgrid-{{ section.id }}">
  <div class="pf-wrap">
    <div class="pf-cathead">
      <span class="pf-eyebrow">🛒 Mua sắm theo danh mục</span>
      <h2 class="pf-title">{{ section.settings.heading }}</h2>
    </div>
    <div class="pf-grid" style="--pf-cols: {{ section.blocks.size | at_most: 6 }};">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- if block.settings.label != blank -%}
          {%- assign cat_label = block.settings.label -%}
        {%- elsif col != blank -%}
          {%- assign cat_label = col.title -%}
        {%- else -%}
          {%- assign cat_label = 'Tên danh mục' -%}
        {%- endif -%}
        {%- if col != blank -%}{%- assign cat_url = col.url -%}{%- else -%}{%- assign cat_url = '#' -%}{%- endif -%}
        <div class="pf-cat" {{ block.shopify_attributes }}>
          <a class="thumb" href="{{ cat_url }}" aria-label="{{ cat_label | escape }}">
            {%- if col != blank and col.image -%}
              <img src="{{ col.image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy" width="300" height="300">
            {%- elsif col != blank and col.products.first.featured_image -%}
              <img src="{{ col.products.first.featured_image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy" width="300" height="300">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>
          <a class="name" href="{{ cat_url }}">{{ cat_label }}</a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Danh Mục Sản Phẩm",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Danh Mục Sản Phẩm" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Ô danh mục",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
        { "type": "text", "id": "label", "label": "Tên hiển thị (nếu chưa chọn bộ sưu tập)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Danh Mục Sản Phẩm",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
