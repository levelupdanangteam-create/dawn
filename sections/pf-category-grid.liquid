<style>
  #pf-catgrid-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #pf-catgrid-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  #pf-catgrid-{{ section.id }} .pf-cathead { text-align: center; margin-bottom: 2.8rem; }
  #pf-catgrid-{{ section.id }} .pf-eyebrow { display: inline-block; font-size: 1.2rem; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; color: #1e63c8; margin-bottom: .8rem; }
  #pf-catgrid-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; color: #2a2622;
    font-size: clamp(2.2rem, 3.4vw, 3.2rem); margin: 0; line-height: 1.15;
  }
  #pf-catgrid-{{ section.id }} .pf-title::after { content: ""; display: block; width: 6rem; height: 4px; border-radius: 4px; margin: 1.2rem auto 0; background: linear-gradient(90deg, #1e63c8, #6aa0ef); }

  #pf-catgrid-{{ section.id }} .pf-grid { display: grid; grid-template-columns: repeat(var(--pf-cols, 5), 1fr); gap: 1.8rem; max-width: 98rem; margin-inline: auto; }
  #pf-catgrid-{{ section.id }} .pf-cat {
    display: flex; flex-direction: column; align-items: center; gap: 1.3rem; text-align: center;
    background: #fff; border: 1px solid #eee; border-radius: 18px; padding: 2.2rem 1.2rem 1.9rem;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:hover { transform: translateY(-5px); box-shadow: 0 16px 32px rgba(30,60,120,.13); border-color: #cfe0fb; }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb {
    width: 9.6rem; height: 9.6rem; border-radius: 50%; overflow: hidden; display: grid; place-items: center;
    border: 3px solid #fff; box-shadow: 0 6px 16px rgba(30,60,120,.12); color: #1e63c8;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:nth-child(5n+1) .thumb { background: #eaf1fb; }
  #pf-catgrid-{{ section.id }} .pf-cat:nth-child(5n+2) .thumb { background: #eafaf1; }
  #pf-catgrid-{{ section.id }} .pf-cat:nth-child(5n+3) .thumb { background: #fdf3e6; }
  #pf-catgrid-{{ section.id }} .pf-cat:nth-child(5n+4) .thumb { background: #fbeaf0; }
  #pf-catgrid-{{ section.id }} .pf-cat:nth-child(5n+5) .thumb { background: #f0eafb; }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s ease; }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .thumb img { transform: scale(1.08); }
  #pf-catgrid-{{ section.id }} .pf-cat .name { font-size: 1.4rem; font-weight: 700; color: #2a2622; line-height: 1.3; }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .name { color: #1e63c8; }
  @media (max-width: 989px) { #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 599px) { #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; } }
</style>

<div id="pf-catgrid-{{ section.id }}" class="pf-boxed-section">
  <div class="pf-wrap">
    <div class="pf-cathead">
      <span class="pf-eyebrow">🛒 Mua sắm theo danh mục</span>
      <h2 class="pf-title">{{ section.settings.heading }}</h2>
    </div>
    <div class="pf-grid" style="--pf-cols: {{ section.blocks.size | at_most: 6 }};">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        <a
          class="pf-cat"
          {% if col != blank %}href="{{ col.url }}"{% else %}href="#" role="link" aria-disabled="true"{% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="thumb">
            {%- if col != blank and col.image -%}
              <img src="{{ col.image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy" width="300" height="300">
            {%- elsif col != blank and col.products.first.featured_image -%}
              <img src="{{ col.products.first.featured_image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy" width="300" height="300">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </span>
          <span class="name">
            {%- if block.settings.label != blank -%}{{ block.settings.label }}{%- elsif col != blank -%}{{ col.title }}{%- else -%}Tên danh mục{%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Danh Mục Sản Phẩm",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Danh Mục Sản Phẩm" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Ô danh mục",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
        { "type": "text", "id": "label", "label": "Tên hiển thị (nếu chưa chọn bộ sưu tập)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Danh Mục Sản Phẩm",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
