<style>
  #pf-catgrid-{{ section.id }} {
    background: #ffffff;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #pf-catgrid-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: 2rem; }
  #pf-catgrid-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; color: #1a1a1a;
    font-size: 2.2rem; margin: 0 0 2.4rem; text-align: center;
  }
  #pf-catgrid-{{ section.id }} .pf-grid { display: grid; grid-template-columns: repeat(var(--pf-cols, 6), 1fr); gap: 1.6rem; max-width: 96rem; margin-inline: auto; }
  #pf-catgrid-{{ section.id }} .pf-cat { display: flex; flex-direction: column; align-items: center; gap: 1rem; text-align: center; }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb {
    width: 100%; aspect-ratio: 1; border-radius: 14px; overflow: hidden; background: #f5f0e8;
    display: grid; place-items: center; border: 1px solid #eee; transition: transform .16s ease, box-shadow .16s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat:hover .thumb { transform: translateY(-3px); box-shadow: 0 10px 22px rgba(0,0,0,.08); }
  #pf-catgrid-{{ section.id }} .pf-cat .thumb img, #pf-catgrid-{{ section.id }} .pf-cat .thumb svg { width: 100%; height: 100%; object-fit: cover; }
  #pf-catgrid-{{ section.id }} .pf-cat .name { font-size: 1.3rem; font-weight: 700; color: #1a1a1a; line-height: 1.3; }
  @media (max-width: 749px) { #pf-catgrid-{{ section.id }} .pf-grid { grid-template-columns: repeat(3, 1fr); } }
</style>

<div id="pf-catgrid-{{ section.id }}" class="pf-boxed-section">
  <div class="pf-wrap">
    <h2 class="pf-title">{{ section.settings.heading }}</h2>
    <div class="pf-grid" style="--pf-cols: {{ section.blocks.size | at_most: 6 }};">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        <a
          class="pf-cat"
          {% if col != blank %}href="{{ col.url }}"{% else %}href="#" role="link" aria-disabled="true"{% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="thumb">
            {%- if col != blank and col.image -%}
              <img src="{{ col.image | image_url: width: 400 }}" alt="{{ col.title | escape }}" loading="lazy" width="400" height="400">
            {%- elsif col != blank and col.products.first.featured_image -%}
              <img src="{{ col.products.first.featured_image | image_url: width: 400 }}" alt="{{ col.title | escape }}" loading="lazy" width="400" height="400">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </span>
          <span class="name">
            {%- if col != blank -%}{{ col.title }}{%- else -%}{{ block.settings.label | default: 'Tên danh mục' }}{%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Danh Mục Sản Phẩm",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Danh Mục Sản Phẩm" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Ô danh mục",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
        { "type": "text", "id": "label", "label": "Tên hiển thị (nếu chưa chọn bộ sưu tập)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Danh Mục Sản Phẩm",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
