<style>
  #pf-catgrid-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #pf-catgrid-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  #pf-catgrid-{{ section.id }} .pf-cathead { text-align: center; margin-bottom: 3.4rem; }
  #pf-catgrid-{{ section.id }} .pf-ornament { display: flex; align-items: center; justify-content: center; gap: 1.2rem; margin-bottom: 1rem; }
  #pf-catgrid-{{ section.id }} .pf-ornament .line { width: clamp(3rem, 8vw, 6rem); height: 1px; background: linear-gradient(90deg, transparent, #d62828); }
  #pf-catgrid-{{ section.id }} .pf-ornament .line + .line { background: linear-gradient(90deg, #d62828, transparent); }
  #pf-catgrid-{{ section.id }} .pf-ornament .dia { width: 9px; height: 9px; background: #d62828; transform: rotate(45deg); }
  #pf-catgrid-{{ section.id }} .pf-titlerow { position: relative; display: flex; align-items: center; justify-content: center; gap: 1.2rem; }
  #pf-catgrid-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; margin: 0;
    font-size: clamp(2.4rem, 3.8vw, 3.4rem); line-height: 1.15;
    color: #d62828; background: linear-gradient(90deg, #d62828 0%, #e8452f 55%, #f2792a 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  #pf-catgrid-{{ section.id }} .pf-all-link {
    position: absolute; right: 0; top: 50%; transform: translateY(-50%);
    display: inline-flex; align-items: center; gap: .5rem; text-decoration: none; white-space: nowrap;
    font-size: 1.45rem; font-weight: 800; color: #1e63c8;
  }
  #pf-catgrid-{{ section.id }} .pf-all-link:hover { color: #d62828; }
  #pf-catgrid-{{ section.id }} .pf-all-link .arw { transition: transform .18s ease; }
  #pf-catgrid-{{ section.id }} .pf-all-link:hover .arw { transform: translateX(4px); }

  #pf-catgrid-{{ section.id }} .pf-grid2 { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.4rem, 2.2vw, 2.2rem); max-width: 116rem; margin-inline: auto; }
  #pf-catgrid-{{ section.id }} .pf-cat2 {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: #f3f1ec; border: 1px solid #ece7dd; border-radius: 16px; padding: 1.8rem 2rem;
    text-decoration: none; min-height: 13rem; overflow: hidden;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  #pf-catgrid-{{ section.id }} .pf-cat2:hover { transform: translateY(-5px); box-shadow: 0 16px 32px rgba(120,100,70,.16); border-color: #d9cdb6; }
  #pf-catgrid-{{ section.id }} .pf-cat2__text { display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; min-width: 0; }
  #pf-catgrid-{{ section.id }} .pf-cat2__name { font-size: clamp(1.7rem, 1.6vw, 2rem); font-weight: 800; color: #2a2622; line-height: 1.25; }
  #pf-catgrid-{{ section.id }} .pf-cat2__badge {
    display: inline-block; background: var(--pf-badge, #22a45d); color: #fff; font-weight: 700;
    font-size: 1.45rem; padding: .7rem 1.3rem; border-radius: 8px; white-space: nowrap; box-shadow: 0 6px 14px rgba(0,0,0,.12);
  }
  #pf-catgrid-{{ section.id }} .pf-cat2__img { flex: none; width: 44%; max-width: 15rem; display: grid; place-items: center; }
  #pf-catgrid-{{ section.id }} .pf-cat2__img img { width: 100%; height: 11rem; object-fit: contain; transition: transform .3s ease; }
  #pf-catgrid-{{ section.id }} .pf-cat2:hover .pf-cat2__img img { transform: scale(1.06); }

  @media (max-width: 989px) { #pf-catgrid-{{ section.id }} .pf-grid2 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 599px) {
    #pf-catgrid-{{ section.id }} .pf-grid2 { grid-template-columns: 1fr; }
    #pf-catgrid-{{ section.id }} .pf-titlerow { flex-direction: column; }
    #pf-catgrid-{{ section.id }} .pf-all-link { position: static; transform: none; margin-top: .8rem; }
  }
</style>

<div id="pf-catgrid-{{ section.id }}">
  <div class="pf-wrap">
    <div class="pf-cathead">
      <div class="pf-ornament" aria-hidden="true">
        <span class="line"></span>
        <span class="dia"></span>
        <span class="line"></span>
      </div>
      <div class="pf-titlerow">
        <h2 class="pf-title">{{ section.settings.heading }}</h2>
        {%- if section.settings.show_all_button -%}
          <a class="pf-all-link" href="{{ section.settings.all_button_link | default: routes.collections_url }}">
            {{ section.settings.all_button_label | default: 'Xem tất cả danh mục' }}
            <span class="arw" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- assign palette = 'seed' | split: ',' -%}
    <div class="pf-grid2">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- if block.settings.label != blank -%}{%- assign cat_label = block.settings.label -%}
        {%- elsif col != blank -%}{%- assign cat_label = col.title -%}
        {%- else -%}{%- assign cat_label = 'Tên danh mục' -%}{%- endif -%}
        {%- if col != blank -%}{%- assign cat_url = col.url -%}{%- else -%}{%- assign cat_url = '#' -%}{%- endif -%}

        {%- comment -%} Badge color: block setting or cycle a default palette {%- endcomment -%}
        {%- assign badge = block.settings.badge_color -%}
        {%- if badge == blank -%}
          {%- assign m = forloop.index0 | modulo: 5 -%}
          {%- case m -%}
            {%- when 0 -%}{%- assign badge = '#22a45d' -%}
            {%- when 1 -%}{%- assign badge = '#e0a92a' -%}
            {%- when 2 -%}{%- assign badge = '#d64545' -%}
            {%- when 3 -%}{%- assign badge = '#1e63c8' -%}
            {%- else -%}{%- assign badge = '#0ca7a0' -%}
          {%- endcase -%}
        {%- endif -%}

        {%- comment -%} Price text: manual, else lowest product price of the collection {%- endcomment -%}
        {%- assign price_text = block.settings.price_text -%}
        {%- if price_text == blank and col != blank and col.products.size > 0 -%}
          {%- assign minp = col.products.first.price -%}
          {%- for p in col.products -%}{%- if p.price < minp -%}{%- assign minp = p.price -%}{%- endif -%}{%- endfor -%}
          {%- capture price_text -%}Giá chỉ từ {{ minp | money }}{%- endcapture -%}
        {%- endif -%}

        <a class="pf-cat2" href="{{ cat_url }}" style="--pf-badge: {{ badge }};" {{ block.shopify_attributes }}>
          <div class="pf-cat2__text">
            <span class="pf-cat2__name">{{ cat_label }}</span>
            {%- if price_text != blank -%}<span class="pf-cat2__badge">{{ price_text }}</span>{%- endif -%}
          </div>
          <div class="pf-cat2__img">
            {%- if block.settings.image_url != blank -%}
              <img src="{{ block.settings.image_url }}" alt="{{ cat_label | escape }}" loading="lazy">
            {%- elsif block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ cat_label | escape }}" loading="lazy">
            {%- elsif col != blank and col.image -%}
              <img src="{{ col.image | image_url: width: 400 }}" alt="{{ cat_label | escape }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Danh Mục Sản Phẩm",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Danh Mục Sản Phẩm" },
    { "type": "checkbox", "id": "show_all_button", "label": "Hiện link \"Xem tất cả danh mục\"", "default": true },
    { "type": "text", "id": "all_button_label", "label": "Chữ của link", "default": "Xem tất cả danh mục" },
    { "type": "url", "id": "all_button_link", "label": "Liên kết (mặc định: trang bộ sưu tập)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Ô danh mục",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
        { "type": "text", "id": "label", "label": "Tên hiển thị (nếu chưa chọn bộ sưu tập)" },
        { "type": "image_picker", "id": "image", "label": "Ảnh (tải lên)" },
        { "type": "text", "id": "image_url", "label": "Hoặc dán URL ảnh" },
        { "type": "text", "id": "price_text", "label": "Chữ badge giá", "info": "Để trống sẽ tự lấy giá thấp nhất của bộ sưu tập." },
        { "type": "color", "id": "badge_color", "label": "Màu badge" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Danh Mục Sản Phẩm",
      "blocks": [
        { "type": "category" }, { "type": "category" }, { "type": "category" },
        { "type": "category" }, { "type": "category" }, { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
