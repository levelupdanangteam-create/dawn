{{ 'phomifood.css' | asset_url | stylesheet_tag }}

<style>
  #pf-promo-{{ section.id }} { background: var(--pf-cream); }
  #pf-promo-{{ section.id }} .pf-wrap {
    display: grid; grid-template-columns: auto repeat({{ section.blocks.size }}, 1fr);
    gap: 1.8rem; align-items: center; padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
  }
  #pf-promo-{{ section.id }} .pf-lead {
    font-family: var(--pf-script); font-style: italic; font-weight: 700;
    color: var(--pf-red); font-size: 2.6rem; line-height: 1.05;
  }
  #pf-promo-{{ section.id }} .pf-lead u { text-decoration: none; border-bottom: 2px solid var(--pf-gold); }
  #pf-promo-{{ section.id }} .pf-ptier {
    display: flex; align-items: center; gap: 1.4rem; background: #fff;
    border: 1px solid var(--pf-line); border-radius: 1.4rem; padding: 1.6rem 1.8rem; box-shadow: var(--pf-shadow);
  }
  #pf-promo-{{ section.id }} .pf-ptier .ic { width: 4.4rem; height: 4.4rem; flex: none; }
  #pf-promo-{{ section.id }} .pf-ptier.red .ic { color: var(--pf-red); }
  #pf-promo-{{ section.id }} .pf-ptier.green .ic { color: var(--pf-green); }
  #pf-promo-{{ section.id }} .pf-ptier .k { font-size: 1.15rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; color: var(--pf-muted); }
  #pf-promo-{{ section.id }} .pf-ptier .k b { color: var(--pf-green); }
  #pf-promo-{{ section.id }} .pf-ptier .v { font-weight: 800; font-size: 2.4rem; color: var(--pf-ink); line-height: 1.1; }
  @media screen and (max-width: 989px) {
    #pf-promo-{{ section.id }} .pf-wrap { grid-template-columns: 1fr 1fr; }
    #pf-promo-{{ section.id }} .pf-lead { grid-column: 1 / -1; text-align: center; }
  }
  @media screen and (max-width: 520px) {
    #pf-promo-{{ section.id }} .pf-wrap { grid-template-columns: 1fr; }
  }
</style>

<div id="pf-promo-{{ section.id }}" class="pf-section">
  <div class="pf-wrap">
    {%- if section.settings.lead != blank -%}
      <div class="pf-lead">{{ section.settings.lead }}</div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      <div class="pf-ptier {{ block.settings.color }}" {{ block.shopify_attributes }}>
        <span class="ic" aria-hidden="true">
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v8H3z"/><path d="M14 10h4l3 3v2h-7z"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
            {%- when 'gift' -%}
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="13" rx="1.5"/><path d="M3 8V6h18v2M12 8v13M12 8S9 3 6.5 4.5 9 8 12 8Zm0 0s3-5 5.5-3.5S15 8 12 8Z"/></svg>
            {%- when 'heart' -%}
              <svg width="44" height="44" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 21s-7-4.6-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.4-7 10-7 10Z"/></svg>
            {%- else -%}
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
          {%- endcase -%}
        </span>
        <div class="t">
          <div class="k">{{ block.settings.kicker }}</div>
          <div class="v">{{ block.settings.value }}</div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Phomifood Ưu đãi",
  "tag": "section",
  "class": "pf-promo-section",
  "max_blocks": 4,
  "settings": [
    { "type": "inline_richtext", "id": "lead", "label": "Tiêu đề viết tay", "default": "Đừng quên <u>ưu đãi!</u>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 34 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 34 }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Mốc ưu đãi",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Biểu tượng",
          "options": [
            { "value": "truck", "label": "Xe giao hàng" },
            { "value": "gift", "label": "Quà tặng" },
            { "value": "heart", "label": "Trái tim" }
          ],
          "default": "truck"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Màu biểu tượng",
          "options": [
            { "value": "red", "label": "Đỏ" },
            { "value": "green", "label": "Xanh lá" }
          ],
          "default": "red"
        },
        { "type": "inline_richtext", "id": "kicker", "label": "Dòng nhỏ", "default": "Freeship" },
        { "type": "text", "id": "value", "label": "Dòng lớn", "default": "từ €150" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Phomifood Ưu đãi",
      "blocks": [
        { "type": "tier", "settings": { "icon": "truck", "color": "red", "kicker": "Freeship", "value": "từ €150" } },
        { "type": "tier", "settings": { "icon": "gift", "color": "green", "kicker": "Freeship + <b>giảm 3%</b>", "value": "từ €250" } },
        { "type": "tier", "settings": { "icon": "heart", "color": "green", "kicker": "Freeship + <b>giảm 5%</b>", "value": "từ €400" } }
      ]
    }
  ]
}
{% endschema %}
