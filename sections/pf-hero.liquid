{{ 'phomifood.css' | asset_url | stylesheet_tag }}

<style>
  #pf-hero-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  #pf-hero-{{ section.id }} .pf-hero-banner {
    position: relative; border-radius: 2.4rem; overflow: hidden;
    background:
      radial-gradient(120% 120% at 88% 30%, rgba(255,255,255,.35), transparent 60%),
      linear-gradient(120deg, {{ section.settings.bg_from }}, {{ section.settings.bg_to }});
    display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center;
    min-height: 42rem;
  }
  #pf-hero-{{ section.id }} .pf-hero-banner::before {
    content: ""; position: absolute; inset: 0; opacity: .5;
    background-image:
      radial-gradient(circle at 12% 20%, rgba(30,107,30,.06) 0 2px, transparent 3px),
      radial-gradient(circle at 30% 70%, rgba(30,107,30,.05) 0 2px, transparent 3px),
      radial-gradient(circle at 60% 40%, rgba(30,107,30,.05) 0 2px, transparent 3px);
    background-size: 26rem 26rem;
  }
  #pf-hero-{{ section.id }} .pf-hero-inner { position: relative; z-index: 1; padding: 4rem clamp(2rem, 4vw, 5rem); }
  #pf-hero-{{ section.id }} .pf-hero-h {
    margin: 0; font-family: var(--font-heading-family); font-weight: 800; letter-spacing: -0.02em;
    color: var(--pf-ink); font-size: clamp(3.2rem, 5vw, 5rem); line-height: 1.05;
  }
  #pf-hero-{{ section.id }} .pf-hero-h .accent { color: var(--pf-green); }
  #pf-hero-{{ section.id }} .pf-hero-sub { margin: 1.6rem 0 0; color: #4c5647; font-size: clamp(1.5rem, 2vw, 1.9rem); max-width: 34ch; }
  #pf-hero-{{ section.id }} .pf-hero-media { position: relative; z-index: 1; align-self: stretch; }
  #pf-hero-{{ section.id }} .pf-hero-media img { width: 100%; height: 100%; object-fit: contain; object-position: center bottom; }
  #pf-hero-{{ section.id }} .pf-hero-media .pf-still {
    width: 100%; height: 100%; min-height: 30rem;
    background: radial-gradient(60% 60% at 60% 55%, rgba(255,255,255,.5), transparent 70%);
    display: grid; place-items: center; color: var(--pf-green);
  }

  /* subscribe form */
  #pf-hero-{{ section.id }} .pf-subscribe { display: flex; max-width: 40rem; margin-top: 3rem; background: #fff; border-radius: 999px; padding: 0.5rem; box-shadow: var(--pf-shadow); }
  #pf-hero-{{ section.id }} .pf-subscribe input {
    flex: 1; min-width: 0; border: 0; background: transparent; padding: 0 1.8rem; font-size: 1.5rem; color: var(--pf-ink);
  }
  #pf-hero-{{ section.id }} .pf-subscribe input:focus { outline: none; }
  #pf-hero-{{ section.id }} .pf-subscribe button {
    border: 0; background: var(--pf-green); color: #fff; font-weight: 800; letter-spacing: 0.03em;
    padding: 1.3rem 2.6rem; border-radius: 999px; cursor: pointer; white-space: nowrap;
  }
  #pf-hero-{{ section.id }} .pf-subscribe button:hover { background: var(--pf-green-deep); }
  #pf-hero-{{ section.id }} .pf-hero-success { margin-top: 1.4rem; color: var(--pf-green-deep); font-weight: 700; }

  /* slider dots (decorative) */
  #pf-hero-{{ section.id }} .pf-dots { position: absolute; bottom: 1.6rem; left: 0; right: 0; display: flex; gap: 0.7rem; justify-content: center; z-index: 2; }
  #pf-hero-{{ section.id }} .pf-dots span { width: 0.9rem; height: 0.9rem; border-radius: 50%; background: rgba(30,107,30,.25); }
  #pf-hero-{{ section.id }} .pf-dots span.on { background: var(--pf-green); width: 2.2rem; border-radius: 999px; }

  @media screen and (max-width: 749px) {
    #pf-hero-{{ section.id }} .pf-hero-banner { grid-template-columns: 1fr; min-height: 0; }
    #pf-hero-{{ section.id }} .pf-hero-media { order: 2; }
    #pf-hero-{{ section.id }} .pf-hero-media img, #pf-hero-{{ section.id }} .pf-hero-media .pf-still { min-height: 22rem; max-height: 30rem; }
  }
</style>

<div id="pf-hero-{{ section.id }}" class="pf-section">
  <div class="pf-wrap">
    <div class="pf-hero-banner">
      <div class="pf-hero-inner">
        <h1 class="pf-hero-h">{{ section.settings.heading }}</h1>
        {%- if section.settings.subheading != blank -%}
          <p class="pf-hero-sub">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.show_subscribe -%}
          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="pf-subscribe">
              <input
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.subscribe_placeholder }}"
                aria-label="{{ section.settings.subscribe_placeholder }}"
                required
              >
              <button type="submit">{{ section.settings.subscribe_label }}</button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="pf-hero-success">{{ 'newsletter.success' | t }}</p>
            {%- endif -%}
          {%- endform -%}
        {%- elsif section.settings.button_label != blank -%}
          <div style="margin-top:3rem;">
            <a class="pf-btn" href="{{ section.settings.button_link | default: '#' }}">
              {{ section.settings.button_label }}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>
        {%- endif -%}
      </div>

      <div class="pf-hero-media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'eager', sizes: '(max-width: 749px) 100vw, 50vw', widths: '400, 600, 800, 1100' }}
        {%- else -%}
          <div class="pf-still" role="img" aria-label="Ảnh sản phẩm">
            <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M6 11c.6-3 3-5 6-5s5.4 2 6 5"/><path d="M12 2v3"/></svg>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.show_dots -%}
        <div class="pf-dots" aria-hidden="true"><span class="on"></span><span></span></div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Phomifood Hero",
  "tag": "section",
  "class": "pf-hero-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Đặc sản Việt · Ưu đãi lớn" },
    { "type": "text", "id": "subheading", "label": "Phụ đề", "default": "Giảm tới 50% cho đơn hàng đầu tiên" },
    { "type": "checkbox", "id": "show_subscribe", "label": "Hiện form đăng ký email", "default": true },
    { "type": "text", "id": "subscribe_placeholder", "label": "Placeholder email", "default": "Nhập email của bạn" },
    { "type": "text", "id": "subscribe_label", "label": "Nhãn nút đăng ký", "default": "Đăng ký" },
    { "type": "text", "id": "button_label", "label": "Nhãn nút (nếu tắt đăng ký)", "default": "Mua ngay" },
    { "type": "url", "id": "button_link", "label": "Liên kết nút" },
    { "type": "image_picker", "id": "image", "label": "Ảnh hero", "info": "Ảnh sản phẩm bên phải. Để trống dùng minh hoạ." },
    { "type": "checkbox", "id": "show_dots", "label": "Hiện chấm slider", "default": true },
    { "type": "color", "id": "bg_from", "label": "Màu nền (trái)", "default": "#DFF0DC" },
    { "type": "color", "id": "bg_to", "label": "Màu nền (phải)", "default": "#EAF1E6" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 16 }
  ],
  "presets": [{ "name": "Phomifood Hero" }]
}
{% endschema %}
