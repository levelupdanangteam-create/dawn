<style>
  #pf-regions-{{ section.id }} {
    background: #ffffff;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #pf-regions-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: 2rem; }
  #pf-regions-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; color: #1a1a1a;
    font-size: 2.2rem; margin: 0 0 2.4rem; text-align: center;
  }
  #pf-regions-{{ section.id }} .pf-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  #pf-regions-{{ section.id }} .pf-col {
    border: 1px solid #ececec; border-radius: 16px; overflow: hidden; background: #fff;
    display: flex; flex-direction: column; transition: box-shadow .16s ease, transform .16s ease;
  }
  #pf-regions-{{ section.id }} .pf-col:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(0,0,0,.09); }
  #pf-regions-{{ section.id }} .pf-col .media { aspect-ratio: 16/10; background: #f5f0e8; display: grid; place-items: center; }
  #pf-regions-{{ section.id }} .pf-col .media img, #pf-regions-{{ section.id }} .pf-col .media svg { width: 100%; height: 100%; object-fit: cover; }
  #pf-regions-{{ section.id }} .pf-col .body { padding: 1.8rem; text-align: center; display: flex; flex-direction: column; gap: 1.4rem; flex: 1; }
  #pf-regions-{{ section.id }} .pf-col .sub { margin: 0; font-family: var(--font-heading-family, sans-serif); font-weight: 700; font-size: 1.8rem; color: #1e63c8; }
  #pf-regions-{{ section.id }} .pf-col .btn {
    margin-top: auto; align-self: center; display: inline-flex; align-items: center; gap: .6rem;
    background: #1e63c8; color: #fff; font-weight: 700; font-size: 1.3rem; padding: 1rem 2rem; border-radius: 8px;
    transition: background .15s ease;
  }
  #pf-regions-{{ section.id }} .pf-col .btn:hover { background: #1e63c8; }
  @media (max-width: 749px) { #pf-regions-{{ section.id }} .pf-cols { grid-template-columns: 1fr; } }
</style>

<div id="pf-regions-{{ section.id }}" class="pf-boxed-section">
  <div class="pf-wrap">
    <h2 class="pf-title">{{ section.settings.heading }}</h2>
    <div class="pf-cols">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        <div class="pf-col" {{ block.shopify_attributes }}>
          <div class="media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.subtitle | escape }}" loading="lazy" width="700" height="440">
            {%- elsif col != blank and col.image -%}
              <img src="{{ col.image | image_url: width: 700 }}" alt="{{ col.title | escape }}" loading="lazy" width="700" height="440">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="body">
            <p class="sub">{{ block.settings.subtitle }}</p>
            <a class="btn" {% if col != blank %}href="{{ col.url }}"{% else %}href="#"{% endif %}>
              Xem thêm
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Đặc Sản 3 Miền",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Đặc Sản 3 Miền" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "blocks": [
    {
      "type": "region",
      "name": "Miền",
      "settings": [
        { "type": "text", "id": "subtitle", "label": "Tiêu đề phụ", "default": "Miền Bắc" },
        { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
        { "type": "image_picker", "id": "image", "label": "Ảnh (tuỳ chọn)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Đặc Sản 3 Miền",
      "blocks": [
        { "type": "region", "settings": { "subtitle": "Miền Bắc" } },
        { "type": "region", "settings": { "subtitle": "Miền Trung" } },
        { "type": "region", "settings": { "subtitle": "Miền Nam" } }
      ]
    }
  ]
}
{% endschema %}
