<style>
  #pf-snacks-{{ section.id }} {
    background: #fff8f0;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #pf-snacks-{{ section.id }} .pf-wrap { max-width: var(--page-width, 120rem); margin-inline: auto; padding-inline: 2rem; }
  #pf-snacks-{{ section.id }} .pf-title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; color: #1a1a1a;
    font-size: 2.2rem; margin: 0 0 2.4rem;
  }
  #pf-snacks-{{ section.id }} .pf-row { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1.6rem; }
  #pf-snacks-{{ section.id }} .pf-card {
    display: block; background: #fff; border: 1px solid #efe6da; border-radius: 12px; overflow: hidden;
    transition: box-shadow .16s ease, transform .16s ease;
  }
  #pf-snacks-{{ section.id }} .pf-card:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(0,0,0,.08); }
  #pf-snacks-{{ section.id }} .pf-media { aspect-ratio: 1; background: #f7f1e8; display: grid; place-items: center; }
  #pf-snacks-{{ section.id }} .pf-media img, #pf-snacks-{{ section.id }} .pf-media svg { width: 100%; height: 100%; object-fit: cover; }
  #pf-snacks-{{ section.id }} .pf-info { padding: 1.1rem 1.2rem 1.4rem; }
  #pf-snacks-{{ section.id }} .pf-name { margin: 0 0 .5rem; font-size: 1.3rem; font-weight: 600; color: #1a1a1a; line-height: 1.35; }
  #pf-snacks-{{ section.id }} .pf-price { font-size: 1.4rem; font-weight: 800; color: #C8870A; }
  @media (max-width: 989px) { #pf-snacks-{{ section.id }} .pf-row { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 599px) { #pf-snacks-{{ section.id }} .pf-row { grid-template-columns: repeat(2, 1fr); } }
</style>

<div id="pf-snacks-{{ section.id }}">
  <div class="pf-wrap">
    <h2 class="pf-title">{{ section.settings.heading }}</h2>
    <div class="pf-row">
      {%- if section.settings.collection != blank and section.settings.collection.products_count > 0 -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <div class="pf-card">
            <a class="pf-media" href="{{ product.url }}">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy" width="400" height="400">
              {%- else -%}
                {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <div class="pf-info">
              <h3 class="pf-name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="pf-price">{{ product.price | money }}</div>
              {% render 'pf-card-buttons', product: product, section_id: section.id %}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="pf-card">
            <div class="pf-media">{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="pf-info">
              <h3 class="pf-name">Tên sản phẩm</h3>
              <div class="pf-price">0&nbsp;€</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ăn Vặt",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Tiêu đề", "default": "Ăn Vặt" },
    { "type": "collection", "id": "collection", "label": "Bộ sưu tập" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 6, "step": 1, "label": "Số sản phẩm hiển thị", "default": 6 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 48 }
  ],
  "presets": [{ "name": "Ăn Vặt" }]
}
{% endschema %}
