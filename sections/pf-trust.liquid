{{ 'phomifood.css' | asset_url | stylesheet_tag }}

<style>
  #pf-trust-{{ section.id }} { background: var(--pf-cream-2); border-block: 1px solid var(--pf-line); }
  #pf-trust-{{ section.id }} .pf-wrap {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 1rem; padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
  }
  #pf-trust-{{ section.id }} .pf-tcell { display: flex; align-items: center; gap: 1.2rem; padding-inline: 0.8rem; position: relative; }
  #pf-trust-{{ section.id }} .pf-tcell + .pf-tcell::before {
    content: ""; position: absolute; left: 0; top: 0.8rem; bottom: 0.8rem; width: 1px; background: rgba(120, 80, 40, 0.18);
  }
  #pf-trust-{{ section.id }} .pf-tcell .ic { width: 4rem; height: 4rem; flex: none; display: grid; place-items: center; }
  #pf-trust-{{ section.id }} .pf-tcell.green .ic { color: var(--pf-green); }
  #pf-trust-{{ section.id }} .pf-tcell.red .ic { color: var(--pf-red); }
  #pf-trust-{{ section.id }} .pf-tcell p { margin: 0; font-size: 1.15rem; font-weight: 800; letter-spacing: 0.02em; text-transform: uppercase; color: #4e453d; line-height: 1.3; }
  @media screen and (max-width: 749px) {
    #pf-trust-{{ section.id }} .pf-wrap { grid-template-columns: repeat(2, 1fr); gap: 1.8rem; }
    #pf-trust-{{ section.id }} .pf-tcell + .pf-tcell::before { display: none; }
  }
</style>

<div id="pf-trust-{{ section.id }}" class="pf-section">
  <div class="pf-wrap">
    {%- for block in section.blocks -%}
      <div class="pf-tcell {{ block.settings.color }}" {{ block.shopify_attributes }}>
        <span class="ic" aria-hidden="true">
          {%- case block.settings.icon -%}
            {%- when 'globe' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"/></svg>
            {%- when 'box' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7l8-4 8 4v10l-8 4-8-4z"/><path d="m4 7 8 4 8-4M12 11v10"/></svg>
            {%- when 'star' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.4 5 5.6.6-4 4 1 5.4L12 20l-5 3 1-5.4-4-4 5.6-.6z"/></svg>
            {%- when 'return' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.5 8.5 0 1 1-4.9-7.7"/><path d="M21 4v4h-4"/></svg>
            {%- when 'headset' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13v-1a8 8 0 0 1 16 0v1"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M20 19a4 4 0 0 1-4 3h-2"/></svg>
            {%- when 'truck' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v8H3z"/><path d="M14 10h4l3 3v2h-7z"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
            {%- when 'shield' -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v6c0 5-3.5 7.5-7 9-3.5-1.5-7-4-7-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
            {%- else -%}
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7 9 18l-5-5"/></svg>
          {%- endcase -%}
        </span>
        <p>{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Phomifood Cam kết",
  "tag": "section",
  "class": "pf-trust-section",
  "max_blocks": 6,
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 26 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 26 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Cam kết",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Biểu tượng",
          "options": [
            { "value": "globe", "label": "Quả địa cầu" },
            { "value": "box", "label": "Hộp" },
            { "value": "star", "label": "Ngôi sao" },
            { "value": "return", "label": "Đổi trả" },
            { "value": "headset", "label": "Tai nghe hỗ trợ" },
            { "value": "truck", "label": "Xe giao hàng" },
            { "value": "shield", "label": "Khiên bảo đảm" }
          ],
          "default": "globe"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Màu biểu tượng",
          "options": [
            { "value": "green", "label": "Xanh lá" },
            { "value": "red", "label": "Đỏ" }
          ],
          "default": "green"
        },
        { "type": "text", "id": "text", "label": "Nội dung", "default": "Ship nhanh toàn Châu Âu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Phomifood Cam kết",
      "blocks": [
        { "type": "item", "settings": { "icon": "globe", "color": "green", "text": "Ship nhanh toàn Châu Âu" } },
        { "type": "item", "settings": { "icon": "box", "color": "green", "text": "Đóng gói cẩn thận" } },
        { "type": "item", "settings": { "icon": "star", "color": "red", "text": "Hàng Việt chính hãng" } },
        { "type": "item", "settings": { "icon": "return", "color": "green", "text": "Đổi trả dễ dàng trong 14 ngày" } },
        { "type": "item", "settings": { "icon": "headset", "color": "red", "text": "Hỗ trợ 24/7 bằng tiếng Việt" } }
      ]
    }
  ]
}
{% endschema %}
