{{ 'phomifood.css' | asset_url | stylesheet_tag }}

<style>
  #pf-fcat-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  #pf-fcat-{{ section.id }} .pf-fcat-head { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; margin-bottom: 2.2rem; flex-wrap: wrap; }
  #pf-fcat-{{ section.id }} .pf-fcat-title { margin: 0; font-family: var(--font-heading-family); font-weight: 800; font-size: 2.2rem; color: var(--pf-ink); }
  #pf-fcat-{{ section.id }} .pf-fcat-nav { display: flex; gap: 0.8rem; }
  #pf-fcat-{{ section.id }} .pf-fcat-nav button {
    width: 3.8rem; height: 3.8rem; border-radius: 50%; border: 1px solid var(--pf-line);
    background: #fff; color: var(--pf-green); display: grid; place-items: center; cursor: pointer;
    transition: background .15s ease, border-color .15s ease;
  }
  #pf-fcat-{{ section.id }} .pf-fcat-nav button:hover { background: var(--pf-green); color: #fff; border-color: var(--pf-green); }
  #pf-fcat-{{ section.id }} .pf-fcat-track {
    display: grid; grid-auto-flow: column; grid-auto-columns: minmax(15rem, 1fr);
    gap: 1.6rem; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 1rem;
    scrollbar-width: thin;
  }
  #pf-fcat-{{ section.id }} .pf-fcat-card {
    scroll-snap-align: start; border-radius: 1.6rem; padding: 2rem 1.5rem; text-align: center;
    border: 1px solid rgba(0,0,0,.04); transition: transform .16s ease, box-shadow .16s ease;
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  #pf-fcat-{{ section.id }} .pf-fcat-card:hover { transform: translateY(-4px); box-shadow: var(--pf-lift); }
  #pf-fcat-{{ section.id }} .pf-fcat-card .thumb { width: 8rem; height: 8rem; display: grid; place-items: center; }
  #pf-fcat-{{ section.id }} .pf-fcat-card .thumb img { width: 100%; height: 100%; object-fit: contain; }
  #pf-fcat-{{ section.id }} .pf-fcat-card .thumb svg { color: var(--pf-green); }
  #pf-fcat-{{ section.id }} .pf-fcat-card .nm { font-weight: 700; font-size: 1.35rem; color: var(--pf-ink); line-height: 1.3; }
  #pf-fcat-{{ section.id }} .pf-fcat-card .ct { font-size: 1.15rem; color: var(--pf-muted); }
  @media screen and (max-width: 749px) {
    #pf-fcat-{{ section.id }} .pf-fcat-track { grid-auto-columns: minmax(13rem, 1fr); }
  }
</style>

<div id="pf-fcat-{{ section.id }}" class="pf-section">
  <div class="pf-wrap">
    <div class="pf-fcat-head">
      <h2 class="pf-fcat-title">{{ section.settings.title }}</h2>
      <div class="pf-fcat-nav">
        <button type="button" data-dir="-1" aria-label="Trước">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 6-6 6 6 6"/></svg>
        </button>
        <button type="button" data-dir="1" aria-label="Sau">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
        </button>
      </div>
    </div>

    <div class="pf-fcat-track" id="pf-fcat-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        <a
          class="pf-fcat-card"
          style="background: {{ block.settings.bg_color }};"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% else %}href="#" role="link" aria-disabled="true"{% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="thumb">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.label }}
            {%- else -%}
              <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20c0-9 6-15 16-15 0 10-6 15-16 15Z"/><path d="M4 20C8 14 12 11 18 9"/></svg>
            {%- endif -%}
          </span>
          <span class="nm">{{ block.settings.label }}</span>
          {%- if block.settings.count != blank -%}<span class="ct">{{ block.settings.count }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var track = document.getElementById('pf-fcat-track-{{ section.id }}');
    if (!track) return;
    document.querySelectorAll('#pf-fcat-{{ section.id }} .pf-fcat-nav button').forEach(function (b) {
      b.addEventListener('click', function () {
        track.scrollBy({ left: (parseInt(b.dataset.dir, 10) || 1) * track.clientWidth * 0.8, behavior: 'smooth' });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Phomifood Danh mục",
  "tag": "section",
  "class": "pf-fcat-section",
  "max_blocks": 16,
  "settings": [
    { "type": "text", "id": "title", "label": "Tiêu đề", "default": "Danh mục nổi bật" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách trên", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Khoảng cách dưới", "default": 20 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Danh mục",
      "settings": [
        { "type": "text", "id": "label", "label": "Tên", "default": "Danh mục" },
        { "type": "text", "id": "count", "label": "Số lượng", "default": "10 sản phẩm" },
        { "type": "url", "id": "link", "label": "Liên kết" },
        { "type": "image_picker", "id": "image", "label": "Ảnh (tuỳ chọn)" },
        { "type": "color", "id": "bg_color", "label": "Màu nền thẻ", "default": "#EAF1E6" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Phomifood Danh mục",
      "blocks": [
        { "type": "category", "settings": { "label": "Mì & Bún", "count": "12 sản phẩm", "bg_color": "#EAF1E6" } },
        { "type": "category", "settings": { "label": "Nước mắm", "count": "8 sản phẩm", "bg_color": "#FBF0DD" } },
        { "type": "category", "settings": { "label": "Gia vị", "count": "16 sản phẩm", "bg_color": "#FCE7E4" } },
        { "type": "category", "settings": { "label": "Đồ khô", "count": "10 sản phẩm", "bg_color": "#E7F0F6" } },
        { "type": "category", "settings": { "label": "Đồ uống", "count": "9 sản phẩm", "bg_color": "#F3ECF7" } },
        { "type": "category", "settings": { "label": "Bánh kẹo", "count": "14 sản phẩm", "bg_color": "#EAF1E6" } },
        { "type": "category", "settings": { "label": "Đồ đông lạnh", "count": "7 sản phẩm", "bg_color": "#FBF0DD" } },
        { "type": "category", "settings": { "label": "Đồ ăn nhanh", "count": "11 sản phẩm", "bg_color": "#FCE7E4" } }
      ]
    }
  ]
}
{% endschema %}
