<style>
  .pf-contact { padding: 4rem 0 6rem; }
  .pf-contact__wrap { max-width: 108rem; margin-inline: auto; padding-inline: clamp(1.6rem, 3vw, 3rem); }
  .pf-contact__head { text-align: center; margin-bottom: 3.4rem; }
  .pf-contact__title {
    font-family: var(--font-heading-family, sans-serif); font-weight: 800; margin: 0;
    font-size: clamp(2.6rem, 4vw, 3.6rem); line-height: 1.15;
    color: #1e8541; background: linear-gradient(90deg, #1e8541, #1e63c8); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .pf-contact__title::after { content: ""; display: block; width: 6rem; height: 4px; border-radius: 4px; margin: 1.2rem auto 0; background: linear-gradient(90deg, #1e8541, #1e63c8); }
  .pf-contact__lead { margin: 1.2rem auto 0; max-width: 68rem; text-align: center; font-size: 1.55rem; line-height: 1.7; color: #574f45; }

  .pf-contact__grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: clamp(2rem, 4vw, 3.4rem); align-items: start; }
  .pf-contact__card { background: #fff; border: 1px solid #ece3d4; border-radius: 18px; padding: clamp(2rem, 3vw, 2.8rem); box-shadow: 0 10px 28px rgba(120,100,70,.07); }
  .pf-contact__card h2 { margin: 0 0 1.6rem; font-size: 1.9rem; font-weight: 800; color: #2a2622; }

  .pf-contact__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.4rem; }
  .pf-contact__row { display: flex; align-items: flex-start; gap: 1.2rem; }
  .pf-contact__ic { flex: none; width: 4.4rem; height: 4.4rem; border-radius: 12px; display: grid; place-items: center; font-size: 2rem; background: radial-gradient(circle at 50% 35%, #eaf1fd, #dbe8fb); }
  .pf-contact__row.wa .pf-contact__ic { background: #e4f7ea; }
  .pf-contact__label { font-size: 1.25rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: #8a8175; margin: 0 0 .2rem; }
  .pf-contact__val { font-size: 1.55rem; color: #2a2622; font-weight: 700; line-height: 1.4; margin: 0; }
  .pf-contact__val a { color: #1e63c8; text-decoration: none; }
  .pf-contact__val a:hover { text-decoration: underline; }

  .pf-contact__cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
  .pf-contact__btn { display: inline-flex; align-items: center; gap: .6rem; text-decoration: none; font-weight: 800; font-size: 1.45rem; padding: 1.1rem 1.8rem; border-radius: 12px; color: #fff; transition: filter .15s ease; }
  .pf-contact__btn:hover { filter: brightness(1.07); }
  .pf-contact__btn.wa { background: #25d366; }
  .pf-contact__btn.fb { background: #1877f2; }

  .pf-contact__field { margin-bottom: 1.4rem; }
  .pf-contact__field input, .pf-contact__field textarea {
    width: 100%; border: 1px solid #e0d6c4; border-radius: 12px; padding: 1.2rem 1.4rem;
    font-size: 1.5rem; color: #2a2622; background: #fbf8f2; font-family: inherit;
  }
  .pf-contact__field input:focus, .pf-contact__field textarea:focus { outline: none; border-color: #1e8541; box-shadow: inset 0 0 0 1px #1e8541; background: #fff; }
  .pf-contact__field textarea { min-height: 13rem; resize: vertical; }
  .pf-contact__row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; }
  .pf-contact__submit {
    width: 100%; border: none; cursor: pointer; color: #fff; font-weight: 800; font-size: 1.6rem;
    padding: 1.3rem 1.6rem; border-radius: 12px; background: linear-gradient(90deg, #1e8541, #14672f); transition: filter .15s ease;
  }
  .pf-contact__submit:hover { filter: brightness(1.07); }
  .pf-contact__ok { background: #e4f7ea; border: 1px solid #b7e3c3; color: #14672f; padding: 1.2rem 1.4rem; border-radius: 12px; margin-bottom: 1.6rem; font-size: 1.45rem; font-weight: 700; }
  .pf-contact__err { background: #fdecec; border: 1px solid #f3b7b7; color: #b42318; padding: 1.2rem 1.4rem; border-radius: 12px; margin-bottom: 1.6rem; font-size: 1.4rem; }

  @media (max-width: 749px) {
    .pf-contact__grid { grid-template-columns: 1fr; }
    .pf-contact__row2 { grid-template-columns: 1fr; }
  }
</style>

<div class="pf-contact color-scheme-1">
  <div class="pf-contact__wrap">
    <div class="pf-contact__head">
      <h1 class="pf-contact__title">Liên hệ với Phomifood</h1>
      <p class="pf-contact__lead">
        Bạn cần tư vấn sản phẩm, đặt hàng số lượng lớn hay hợp tác phân phối? Hãy liên hệ với chúng tôi —
        đội ngũ Phomifood luôn sẵn sàng hỗ trợ bạn nhanh nhất.
      </p>
    </div>

    <div class="pf-contact__grid">
      <div class="pf-contact__card">
        <h2>Thông tin liên hệ</h2>
        <ul class="pf-contact__list">
          <li class="pf-contact__row wa">
            <span class="pf-contact__ic" aria-hidden="true">📞</span>
            <div>
              <p class="pf-contact__label">Điện thoại / WhatsApp</p>
              <p class="pf-contact__val"><a href="tel:+84938227250">+84 93 822 72 50</a></p>
            </div>
          </li>
          <li class="pf-contact__row">
            <span class="pf-contact__ic" aria-hidden="true">💬</span>
            <div>
              <p class="pf-contact__label">Fanpage / Messenger</p>
              <p class="pf-contact__val"><a href="https://www.facebook.com/Phomifood" target="_blank" rel="noopener">Phomifood</a></p>
            </div>
          </li>
          <li class="pf-contact__row">
            <span class="pf-contact__ic" aria-hidden="true">📍</span>
            <div>
              <p class="pf-contact__label">Địa chỉ kho</p>
              <p class="pf-contact__val">Chợ Sapa, Cộng hòa Séc</p>
            </div>
          </li>
        </ul>

        <div class="pf-contact__cta">
          <a class="pf-contact__btn wa" href="https://wa.me/84938227250" target="_blank" rel="noopener">💬 Chat WhatsApp</a>
          <a class="pf-contact__btn fb" href="https://www.facebook.com/Phomifood" target="_blank" rel="noopener">📘 Nhắn Fanpage</a>
        </div>
      </div>

      <div class="pf-contact__card">
        <h2>Gửi tin nhắn cho chúng tôi</h2>
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p class="pf-contact__ok">✅ Cảm ơn bạn! Chúng tôi đã nhận được tin nhắn và sẽ liên hệ lại sớm nhất.</p>
          {%- elsif form.errors -%}
            <p class="pf-contact__err">Vui lòng kiểm tra lại thông tin: {{ form.errors | default_errors }}</p>
          {%- endif -%}

          <div class="pf-contact__row2">
            <div class="pf-contact__field">
              <input type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Họ và tên" autocomplete="name">
            </div>
            <div class="pf-contact__field">
              <input type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="Email *" required autocomplete="email">
            </div>
          </div>
          <div class="pf-contact__field">
            <input type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% endif %}" placeholder="Số điện thoại" autocomplete="tel">
          </div>
          <div class="pf-contact__field">
            <textarea name="contact[body]" placeholder="Nội dung tin nhắn...">{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>
          <button type="submit" class="pf-contact__submit">Gửi tin nhắn</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>
